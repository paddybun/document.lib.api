@page "/Document/create"
@using Microsoft.EntityFrameworkCore

@inject IDbContextFactory<DatabaseContext> DbContextFactory


@rendermode InteractiveServer

<RadzenRow>
    <RadzenColumn Size="12">
        <RadzenCard>
            <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
                    <RadzenText TextStyle="TextStyle.Subtitle2" Text="Upload New Document"/>
                    <RadzenUpload @ref="_upload" Url="api/upload/single" Progress="@OnProgress" Error="@OnError" Auto="false"/>        
                </RadzenStack>
                <RadzenButton Text="Upload" Click=@OnUpload class="rz-mt-4" />
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code{
    private byte[] _data;
    private RadzenUpload _upload;
    private string? _docName = null;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }

    private async Task OnProgress(UploadProgressArgs arg)
    {
    }

    private void OnError(UploadErrorEventArgs obj)
    {
        Console.WriteLine(obj.Message);
    }

    private async Task OnUpload(MouseEventArgs arg)
    {
        await _upload.Upload();
    }

}